{
  "permissions": {
    "allow": [
      "Bash(yarn start)",
      "Bash(yarn build)",
      "Bash(yarn build:memory)",
      "Bash(yarn start:preview)",
      "Bash(yarn start:memory)",
      "Bash(yarn start:memory:preview)",
      "Bash(yarn format)",
      "Bash(yarn fix-lint)",
      "Bash(yarn lint-staged)",
      "Bash(yarn check-lint)",
      "Bash(yarn check-types)",
      "Bash(yarn check-format)",
      "Bash(yarn build:test)",
      "Bash(yarn start:test:preview)",
      "Bash(yarn cypress:run:ui)",
      "Bash(yarn cypress:run:ui:mobile)",
      "Bash(yarn test)",
      "Bash(yarn test *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/enforce-yarn.sh"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["chrome-devtools-mcp"]
}
