{
  "name": "my-cv",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "This repository contains all of my cv web",
  "author": "Javier Fajardo García",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaviGF8/my-cv.git"
  },
  "bugs": {
    "url": "https://github.com/JaviGF8/my-cv/issues"
  },
  "homepage": "https://javigf8.github.io/my-cv/",
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check-lint": "eslint .",
    "check-types": "tsc --pretty --noEmit",
    "check-format": "prettier --check .",
    "deploy": "yarn build && gh-pages -d dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "preview": "vite preview",
    "preview:build": "yarn build && vite preview --host 127.0.0.1",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "prepare": "husky",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "yarn check-lint"
    ]
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "i18next": "^26.3.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
